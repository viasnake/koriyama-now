{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "civic-koriyama",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-06-17",
  "workers_dev": false,
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
